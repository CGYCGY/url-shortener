# WorkOS AuthKit (Phase 2)
# Source: WorkOS dashboard → API keys
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
# Generate a 32+ char secret, e.g. `openssl rand -base64 32`
WORKOS_COOKIE_PASSWORD=
# Source: WorkOS dashboard → Webhooks (validates user.* events sent to Convex)
WORKOS_WEBHOOK_SECRET=
# Source: https://s.gylab.cc/callback (prod) or http://localhost:3000/callback (dev)
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# Convex (Phase 1 — populated by `bunx convex dev` on first run)
# Source: Convex CLI on init
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Public origin for building short URLs. Defaults to window.location.origin in the browser.
# Set in prod to https://s.gylab.cc
NEXT_PUBLIC_BASE_URL=

# HMAC secret signing the per-link unlock cookie. 32+ chars.
# Generate with `openssl rand -base64 32`. Rotating invalidates outstanding unlock cookies.
LINK_UNLOCK_COOKIE_SECRET=
